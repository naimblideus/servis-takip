// B) Database Schema - Prisma Schema File
// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANT CORE
// ============================================

model Tenant {
  id             String   @id @default(cuid())
  name           String
  slug           String?  @unique
  logo           String?
  phone          String?
  email          String?
  address        String?
  city           String?
  district       String?
  taxNumber      String?
  taxOffice      String?
  ownerName      String?
  pricePerBlack  Decimal  @default(0.40) @db.Decimal(10, 4)
  pricePerColor  Decimal  @default(1.50) @db.Decimal(10, 4)

  // Sektör
  businessType   String   @default("general")

  // Abonelik
  plan              String   @default("trial")
  planStartDate     DateTime @default(now())
  planEndDate       DateTime?
  trialEndsAt       DateTime?
  isActive          Boolean  @default(true)
  isSuspended       Boolean  @default(false)
  suspendReason     String?

  // Limitler
  maxUsers             Int    @default(2)
  maxTicketsPerMonth   Int?
  storageLimitMB       Float  @default(500)
  storageUsedMB        Float  @default(0)

  // Süper admin notları
  adminNotes           String?

  // Soft delete
  deletedAt            DateTime?

  // Logo entegrasyon ayarları
  logoIntegrationEnabled Boolean @default(false)
  logoIntegrationMethod  String? // rest, file, db
  logoApiUrl             String?
  logoApiKey             String?
  logoFirmaKodu          String?
  logoDonemKodu          String?
  logoDbServer           String?
  logoDbPort             String?
  logoDbName             String?
  logoDbUser             String?
  logoDbPassEncrypted    String?
  logoDefaultCariGrup    String?
  logoDefaultGelirHesap  String?
  logoKasaHesap          String?
  logoBankaHesap         String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  users               User[]
  customers           Customer[]
  devices             Device[]
  serviceTickets      ServiceTicket[]
  counterReadings     CounterReading[]
  parts               Part[]
  ticketParts         TicketPart[]
  payments            Payment[]
  attachments         Attachment[]
  auditLogs           AuditLog[]
  notificationLogs    NotificationLog[]
  transactions        FinancialTransaction[]
  importSessions      ImportSession[]
  subscriptionHistory SubscriptionHistory[]
  invoices            TenantInvoice[]
  logoSyncLogs        LogoSyncLog[]
  printerStocks       PrinterStock[]
  accountEntries      AccountEntry[]

  @@index([isActive])
  @@index([plan])
}

// ============================================
// AUTHENTICATION & USERS
// ============================================

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole @default(TECHNICIAN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTickets ServiceTicket[] @relation("AssignedTechnician")
  createdTickets  ServiceTicket[] @relation("CreatedBy")
  auditLogs       AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId, email])
  @@index([tenantId, role])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TECHNICIAN
  FRONT_DESK
}

// ============================================
// CUSTOMER MANAGEMENT
// ============================================

model Customer {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  phone         String
  address       String?
  taxNo         String?
  email         String?  // E-posta adresi (import'tan gelebilir)
  contactPerson String?  // Yetkili kişi adı
  consent       Boolean  @default(false) // GDPR/KVKK consent
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  devices        Device[]
  transactions   FinancialTransaction[]
  accountEntries AccountEntry[]

  @@unique([tenantId, phone])
  @@index([tenantId, phone])
  @@index([tenantId, name])
}

// ============================================
// DEVICE MANAGEMENT
// ============================================

model Device {
  id          String    @id @default(cuid())
  tenantId    String
  customerId  String
  brand       String
  model       String
  serialNo    String
  location    String?
  isRental       Boolean   @default(false) // Kiralık cihaz mı?
  monthlyRent    Decimal   @default(0) @db.Decimal(10, 2) // Aylık kira bedeli
  pricePerBlack  Decimal?  @db.Decimal(10, 4) // Cihaz bazlı siyah birim fiyat (null=tenant varsayılan)
  pricePerColor  Decimal?  @db.Decimal(10, 4) // Cihaz bazlı renkli birim fiyat (null=tenant varsayılan)
  publicCode     String    @unique // e.g., DEV-8F3A12 (for QR URL)
  qrTokenHash String // Hashed version of QR token
  qrExpiresAt DateTime? // Optional token expiry
  counterBlack  Int?     // Son bilinen siyah sayaç
  counterColor  Int?     // Son bilinen renkli sayaç
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceTickets  ServiceTicket[]
  counterReadings CounterReading[]

  @@unique([tenantId, serialNo])
  @@index([tenantId, customerId])
  @@index([publicCode])
  @@index([tenantId, serialNo])
}

// ============================================
// SERVICE TICKET WORKFLOW
// ============================================

model ServiceTicket {
  id              String        @id @default(cuid())
  tenantId        String
  deviceId        String
  customerId      String // Denormalized for quick access
  ticketNumber    String // Human-readable: TSK-2024-00123
  status          TicketStatus  @default(NEW)
  priority        Priority      @default(NORMAL)
  assignedUserId  String?
  createdByUserId String
  issueTemplate   String? // Predefined template name
  issueText       String
  actionTemplate  String? // Predefined action template
  actionText      String?
  notes           String?
  totalCost       Decimal       @default(0) @db.Decimal(10, 2)
  paymentStatus   PaymentStatus @default(UNPAID)
  statusUpdatedAt DateTime      @default(now())
  deletedAt       DateTime?     // Soft-delete: null = aktif, set = çöp kutusu
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device          Device           @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  assignedUser    User?            @relation("AssignedTechnician", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy       User             @relation("CreatedBy", fields: [createdByUserId], references: [id])
  counterReadings CounterReading[]
  ticketParts     TicketPart[]
  payments        Payment[]
  attachments     Attachment[]
  transactions    FinancialTransaction[]

  @@unique([tenantId, ticketNumber])
  @@index([tenantId, status])
  @@index([tenantId, deviceId])
  @@index([tenantId, customerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, assignedUserId])
  @@index([tenantId, deletedAt])
}

enum TicketStatus {
  NEW
  IN_SERVICE
  WAITING_FOR_PART
  READY
  DELIVERED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

// ============================================
// COUNTER READINGS
// ============================================

model CounterReading {
  id             String   @id @default(cuid())
  tenantId       String
  deviceId       String
  ticketId       String? // Optional: link to service ticket
  readingDate    DateTime @default(now())
  counterBlack   Int
  counterColor   Int
  deltaBlack     Int      @default(0) // Computed from previous reading
  deltaColor     Int      @default(0)
  calculatedCost Decimal  @default(0) @db.Decimal(10, 2) // Hesaplanan ücret
  monthlyRent    Decimal  @default(0) @db.Decimal(10, 2) // Aylık aidat (dahil edildiyse)
  createdAt      DateTime @default(now())

  // Relations
  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  ticket ServiceTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([tenantId, deviceId, readingDate(sort: Desc)])
  @@index([tenantId, ticketId])
}

// ============================================
// PARTS INVENTORY
// ============================================

model Part {
  id        String   @id @default(cuid())
  tenantId  String
  sku       String
  name      String
  buyPrice  Decimal  @default(0) @db.Decimal(10, 2)
  sellPrice Decimal  @default(0) @db.Decimal(10, 2)
  stockQty  Int      @default(0)
  minStock  Int      @default(5) // Low stock threshold
  group     String?  // Ürün grubu: Fırın Grubu, Paten, İşçilik, Dişli Grubu, Yedek Parça, Toner, Tamirat
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketParts TicketPart[]

  @@unique([tenantId, sku])
  @@index([tenantId, name])
  @@index([tenantId, stockQty])
}

model TicketPart {
  id        String   @id @default(cuid())
  tenantId  String
  ticketId  String
  partId    String
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2) // Price at time of use
  createdAt DateTime @default(now())

  // Relations
  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  part   Part          @relation(fields: [partId], references: [id], onDelete: Restrict)

  @@index([tenantId, ticketId])
  @@index([tenantId, partId])
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id          String        @id @default(cuid())
  tenantId    String
  ticketId    String
  amount      Decimal       @db.Decimal(10, 2)
  method      PaymentMethod @default(CASH)
  paymentDate DateTime      @default(now())
  notes       String?
  createdAt   DateTime      @default(now())

  // Relations
  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([tenantId, ticketId])
  @@index([tenantId, paymentDate])
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OPEN_ACCOUNT
  OTHER
}

// ============================================
// ATTACHMENTS (Photos)
// ============================================

model Attachment {
  id        String         @id @default(cuid())
  tenantId  String
  ticketId  String
  url       String // S3/Supabase Storage URL
  type      AttachmentType @default(PHOTO)
  fileSize  Int? // bytes
  createdAt DateTime       @default(now())

  // Relations
  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([tenantId, ticketId])
}

enum AttachmentType {
  PHOTO
  PDF
  OTHER
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String // e.g., "TICKET_CREATED", "STATUS_CHANGED"
  entityType String // e.g., "ServiceTicket", "Device"
  entityId   String
  oldValue   String? // JSON string
  newValue   String? // JSON string
  ipAddress  String?
  createdAt  DateTime @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt(sort: Desc)])
}

// ============================================
// NOTIFICATION LOG (Stub for MVP)
// ============================================

model NotificationLog {
  id        String              @id @default(cuid())
  tenantId  String
  ticketId  String? // Optional link
  recipient String // Phone number or email
  message   String
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  sentAt    DateTime?
  error     String?
  createdAt DateTime            @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
}

enum NotificationChannel {
  SMS
  WHATSAPP
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

// ============================================
// FINANCIAL TRANSACTIONS (MUHASEBE)
// ============================================

model FinancialTransaction {
  id          String              @id @default(cuid())
  tenantId    String
  customerId  String?             // Müşteriye bağlıysa
  ticketId    String?             // Fişe bağlıysa
  readingId   String?             // Sayaç okumasına bağlıysa
  type        TransactionType     // INCOME / EXPENSE
  category    TransactionCategory // SERVİS_ÜCRETİ, SAYAÇ_ÜCRETİ, PARÇA_ALIMI vs.
  amount      Decimal             @db.Decimal(10, 2)
  method      PaymentMethod       @default(CASH) // CASH, CARD, TRANSFER, OTHER
  description String
  date        DateTime            @default(now())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relations
  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  ticket   ServiceTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([tenantId, type, date(sort: Desc)])
  @@index([tenantId, customerId])
  @@index([tenantId, category])
  @@index([tenantId, date(sort: Desc)])
}

enum TransactionType {
  INCOME    // Gelir
  EXPENSE   // Gider
}

enum TransactionCategory {
  SERVICE_FEE      // Servis ücreti
  COUNTER_FEE      // Sayaç okuma ücreti (kiralık)
  RENTAL_FEE       // Aylık kira bedeli
  PART_PURCHASE    // Parça alımı (gider)
  PART_SALE        // Parça satışı (gelir)
  MACHINE_PURCHASE // Makina alımı (gider)
  MACHINE_SALE     // Makina satışı (gelir)
  GENERAL_EXPENSE  // Genel gider
  SALARY           // Maaş
  RENT             // Kira (işyeri)
  UTILITY          // Fatura (elektrik, su vs.)
  TAX              // Vergi
  FOOD             // Yemek
  INSURANCE        // Sigorta
  FUEL             // Yakıt / Ulaşım
  MAINTENANCE      // Bakım / Tadilat
  OTHER_INCOME     // Diğer gelir
  OTHER_EXPENSE    // Diğer gider
}


// ============================================
// IMPORT SESSION (Veri İçe Aktarma)
// ============================================

model ImportSession {
  id           String    @id @default(cuid())
  tenantId     String
  fileName     String
  status       String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  totalRows    Json?     // { musteriler: 0, servisler: 0, urunler: 0, kasa: 0 }
  importedRows Json?     // Başarılı sayılar
  failedRows   Json?     // Başarısız sayılar
  errors       Json?     // Hata detayları: [{row, table, error}]
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("import_sessions")
}

// ============================================
// SÜPER ADMİN
// ============================================

model SuperAdmin {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String    // bcrypt hash
  name        String
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================
// ABONELİK GEÇMİŞİ
// ============================================

model SubscriptionHistory {
  id        String   @id @default(cuid())
  tenantId  String
  plan      String
  action    String   // created, upgraded, downgraded, renewed, suspended, cancelled, activated
  amount    Float?
  notes     String?
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
}

// ============================================
// FATURALAR
// ============================================

model TenantInvoice {
  id            String    @id @default(cuid())
  tenantId      String
  invoiceNumber String    // FAT-2026-0001
  period        String    // "2026-03"
  amount        Float
  vatAmount     Float     @default(0)
  totalAmount   Float
  status        String    @default("pending") // pending, paid, overdue, cancelled
  dueDate       DateTime
  paidDate      DateTime?
  paidAmount    Float?
  paymentMethod String?   // cash, transfer, card
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([status, dueDate])
}

// ============================================
// PLATFORM AYARLARI (global — tüm sistem)
// ============================================

model PlatformSettings {
  id                  String  @id @default(cuid())
  platformName        String  @default("Servis Takip")
  platformLogo        String?
  contactEmail        String?
  defaultTrialDays    Int     @default(14)
  maintenanceMode     Boolean @default(false)
  announcementText    String?
  announcementActive  Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ============================================
// LOGO MUHASEBE SENKRONIZASYON LOG
// ============================================

model LogoSyncLog {
  id           String   @id @default(cuid())
  tenantId     String
  operation    String   // customer_create, customer_update, invoice_create, payment_create, balance_import, stock_movement
  entityType   String   // customer, invoice, payment, stock
  entityId     String?
  direction    String   // export, import
  status       String   // success, error, pending
  requestData  Json?
  responseData Json?
  errorMessage String?
  createdAt    DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, operation])
  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
}

// ============================================
// YAZICI / SARF MALZEME STOĞU
// ============================================

model PrinterStock {
  id          String    @id @default(cuid())
  tenantId    String
  category    String    // TONER | MUREKEP | YAZICI
  brand       String    // Marka: HP, Canon, Epson vs.
  model       String    // Model adı
  condition   String    @default("SIFIR") // SIFIR | IKINCI_EL
  color       String?   // Renk: Siyah, Mavi, Kırmızı, Sarı, Renkli
  quantity    Int       @default(1)
  buyPrice    Decimal   @default(0) @db.Decimal(10, 2)
  sellPrice   Decimal   @default(0) @db.Decimal(10, 2)
  notes       String?
  soldAt      DateTime? // Satış tarihi
  soldTo      String?   // Kime satıldı
  soldPrice   Decimal?  @db.Decimal(10, 2) // Satış fiyatı
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, category])
  @@index([tenantId, brand])
  @@index([tenantId, createdAt(sort: Desc)])
}

// ============================================
// MANUEL MUHASEBE (CARİ HESAP TAKİBİ)
// ============================================

model AccountEntry {
  id          String           @id @default(cuid())
  tenantId    String
  customerId  String
  type        AccountEntryType // SALE veya PAYMENT
  product     String?          // Aldığı ürün/hizmet adı (SALE için)
  amount      Decimal          @db.Decimal(10, 2)
  method      PaymentMethod    @default(CASH) // Nakit, Kredi, IBAN, Açık Hesap
  notes       String?
  date        DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId, date(sort: Desc)])
  @@index([tenantId, type])
  @@index([tenantId, date(sort: Desc)])
}

enum AccountEntryType {
  SALE    // Satış / Ürün teslimi
  PAYMENT // Ödeme alındı
}
